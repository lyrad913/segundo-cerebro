<section class="surface search-wrap" aria-label="게시글 검색">
  <h2 class="search-title en">⌕ Search</h2>
  <div id="search"></div>
</section>

<script is:inline>
  (() => {
    const base = document.querySelector('meta[name="astro-base"]')?.content || '';
    // Dynamically inject pagefind CSS
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = base + '/pagefind/pagefind-ui.css';
    document.head.appendChild(link);

    const init = async () => {
      try {
        const res = await fetch(base + "/pagefind/pagefind-entry.json", {
          method: "HEAD",
        });
        if (!res.ok) return;
        const mod = await import(base + "/pagefind/pagefind-ui.js");
        const PagefindUI = mod.PagefindUI;
        new PagefindUI({
          element: "#search",
          showSubResults: true,
          translations: {
            placeholder: "게시글 검색",
          },
        });
      } catch {}
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, { once: true });
      return;
    }

    init();
  })();
</script>
